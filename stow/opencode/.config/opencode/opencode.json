{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "autoshare": false,
  "autoupdate": true,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "augment-context-engine": {
      "type": "local",
      "command": [
        "/Users/dominikgarciabertapelle/.npm-global/bin/auggie",
        "--mcp",
        "--mcp-auto-workspace"
      ],
      "enabled": true
    },
    "react-grab-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@react-grab/mcp", "--stdio"]
    },
    "fff": {
      "type": "local",
      "command": ["fff-mcp"],
      "enabled": true
    }
  }
}
